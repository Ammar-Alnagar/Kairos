# Kairos — environment variable reference
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is git-ignored and should never be committed.
# Usage (bash):  set -a && source .env && set +a && cargo run
# ─────────────────────────────────────────────────────────────────────────────

# ── Backends ──────────────────────────────────────────────────────────────────
# Comma-separated base URLs of your vLLM (or OpenAI-compatible) instances.
# Kairos will scrape <url>/metrics on each one every 5 s, compute a load score
# (running_requests + waiting_requests * 2), and route all traffic to the
# lowest-scoring (fastest) endpoint first.  Remaining endpoints act as
# automatic fallbacks if the top one is unreachable or returns a non-2xx.
#
# Examples:
#   Single host, two model workers on different ports
#   ENDPOINTS=http://localhost:8000,http://localhost:8001
#
#   Multiple hosts
#   ENDPOINTS=http://gpu-node-1:8000,http://gpu-node-2:8000,http://gpu-node-3:8000
ENDPOINTS=http://<host1>:<port>,http://<host2>:<port>

# ── Proxy server ──────────────────────────────────────────────────────────────
# Port that Kairos binds to.
# Default: 3000
PORT=3000

# ── Logging ───────────────────────────────────────────────────────────────────
# Tracing filter string consumed by tracing-subscriber.
# Levels (least → most verbose): error | warn | info | debug | trace
#
# Examples:
#   Quiet — only errors and warnings
#   RUST_LOG=warn
#
#   Per-module verbosity
#   RUST_LOG=kairos=debug,reqwest=warn
RUST_LOG=info
